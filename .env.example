# Required for POST /api/manual-event, /admin/queue actions and
# POST /api/admin/hero. Set to a long random string in production.
ADMIN_TOKEN=Ahnuska@2026!!

# Path to the SQLite database file. Relative to project root.
DB_PATH=./data/sincewhen.db

# Toggle GDELT candidate pulls for the approval-queue counters.
GDELT_ENABLED=true

# Network timeouts (ms) for outbound fetches.
FETCH_TIMEOUT_MS=15000

# Site base URL used for self-reference (share cards, confirm/unsubscribe
# links in emails). Override in production.
SITE_URL=http://localhost:3000

# ---- Alerts ----
# Resend (https://resend.com) API key. If unset, subscribe/confirm still
# works but emails are logged instead of sent ("dry run" mode).
RESEND_API_KEY=
# From: address used on every outbound email. Must be on a verified domain.
ALERT_FROM_EMAIL=

# ---- Donate ----
# Floating "buy me a pizza slice" pill links here. Leave blank to hide it.
NEXT_PUBLIC_DONATE_URL=
